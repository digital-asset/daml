_choice$_T$SameResultInRollback :
  (DA.Internal.Desugar.Consuming T,
   T -> SameResultInRollback -> [DA.Internal.Desugar.Party],
   DA.Internal.Desugar.Optional (T
                                 -> SameResultInRollback -> [DA.Internal.Desugar.Party]),
   DA.Internal.Desugar.Optional (T
                                 -> SameResultInRollback -> [DA.Internal.Desugar.Party]),
   DA.Internal.Desugar.ContractId T
   -> T -> SameResultInRollback -> DA.Internal.Desugar.Update (()))
_choice$_T$SameResultInRollback
  = (DA.Internal.Desugar.Consuming, 
     \ this@T {..} arg@SameResultInRollback
       -> let _ = this in
          let _ = arg in DA.Internal.Desugar.toParties (p), 
     DA.Internal.Desugar.None, DA.Internal.Desugar.None, 
     \ self this@T {..} arg@SameResultInRollback
       -> let _ = self in
          let _ = this in
          let _ = arg
          in
            do DA.Internal.Desugar._tryCatch
                 \ _
                   -> do cids <- fmap fst <$> lookupNByKey @K 10 p
                         throw $ EWithCids cids
                 \case
                   (DA.Internal.Desugar.fromAnyException -> DA.Internal.Desugar.Some (EWithCids cids))
                     -> DA.Internal.Desugar.Some
                          do cids2 <- fmap fst <$> lookupNByKey @K 10 p
                             cids === cids2
                   _ -> DA.Internal.Desugar.None)
