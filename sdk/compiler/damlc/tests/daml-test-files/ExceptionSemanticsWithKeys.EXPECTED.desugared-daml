_choice$_T$CatchInvalidLookupByKey :
  (DA.Internal.Desugar.Consuming T,
   T -> CatchInvalidLookupByKey -> [DA.Internal.Desugar.Party],
   DA.Internal.Desugar.Optional (T
                                 -> CatchInvalidLookupByKey -> [DA.Internal.Desugar.Party]),
   DA.Internal.Desugar.Optional (T
                                 -> CatchInvalidLookupByKey -> [DA.Internal.Desugar.Party]),
   DA.Internal.Desugar.ContractId T
   -> T -> CatchInvalidLookupByKey -> DA.Internal.Desugar.Update (()))
_choice$_T$CatchInvalidLookupByKey
  = (DA.Internal.Desugar.Consuming, 
     \ this@T {..} arg@CatchInvalidLookupByKey
       -> let _ = this in
          let _ = arg in DA.Internal.Desugar.toParties (p), 
     DA.Internal.Desugar.None, DA.Internal.Desugar.None, 
     \ self this@T {..} arg@CatchInvalidLookupByKey
       -> let _ = self in
          let _ = this in
          let _ = arg
          in
            do DA.Internal.Desugar._tryCatch
                 \ _
                   -> do _ <- lookupNByKey @K (- 1) p
                         pure ()
                 \case
                   (DA.Internal.Desugar.fromAnyException -> DA.Internal.Desugar.Some (GeneralError msg))
                     -> DA.Internal.Desugar.Some
                          msg === "lookupNByKey may not be passed a negative n"
                   _ -> DA.Internal.Desugar.None)
test
  = script
      do p <- allocateParty "p"
         submit p $ forA_ [1 .. 15] $ const $ createCmd $ K p
         submit p $ createAndExerciseCmd (T p) SameResultInRollback
         submit p $ createAndExerciseCmd (T p) NonConsumingExerciseByKey
         submit p $ createAndExerciseCmd (T p) UseLeakedRollbackCid
         submit p $ createAndExerciseCmd (T p) CatchInvalidLookupByKey
         pure ()
