module PatternSynonyms where

import Daml.Script
import DA.Assert

type Box = Optional

pattern Empty : Box a
pattern Empty = None

pattern Filled : a -> Box a
pattern Filled x = Some x

{-# COMPLETE Empty, Filled : Optional #-}

mapOptional : (a -> b) -> Optional a -> Optional b
mapOptional f = \case
  Empty -> Empty
  Filled x -> Filled (f x)

main = script do
  let f : Int -> Text = show
  mapOptional f Empty === Empty
  mapOptional f (Filled 1) === Filled "1"
