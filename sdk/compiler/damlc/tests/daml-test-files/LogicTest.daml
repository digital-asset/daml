module LogicTest where

import Daml.Script
import DA.List
import DA.Logic
import DA.Assert

propositionId : Formula Int -> Int
propositionId (Proposition n) = n
propositionId _ = error "expected proposition"

sortDisjunctionProps : Formula Int -> Formula Int
sortDisjunctionProps (Disjunction ps) = Disjunction (sortOn propositionId ps)
sortDisjunctionProps f = f

propositionTest = script do
  let
    p = Proposition 1
    q = Proposition 2
    r = Proposition 3
    f : Formula Int = false
    t : Formula Int = true
    truth i
      | i == 1 = Some True
      | i == 2 = Some False
      | otherwise = None
  neg p === Negation (Proposition 1)
  (p &&& q) === Conjunction [Proposition 1, Proposition 2]
  disj [p, q] === Disjunction [Proposition 1, Proposition 2]
  (t &&& f) === substitute truth (p &&& q)
  (t &&& f) === Conjunction [Conjunction [], Disjunction []]
  [t,f] === (reduce <$> [t,f])
  f === reduce (true &&& false)
  Right False === interpret truth (p &&& q)
  Right True === interpret truth (neg (p &&& q))
  Right True === interpret truth (p ||| q)
  Right True === interpret truth (p ||| r)
  Right False === interpret truth (q &&& r)
  Disjunction [f, r] === substitute truth (q ||| r)
  Left r === interpret truth (q ||| r)
  interpret truth ( p &&& r) === Left r

reduceTest = script do
  let
    p = Proposition 1
    q = Proposition 2
    r = Proposition 3
    truth i
      | i == 1 = Some True
      | i == 2 = Some False
      | otherwise = None
  sortDisjunctionProps (reduce (Disjunction [Disjunction [p], Disjunction [q]])) ===
    sortDisjunctionProps (Disjunction [p, q])
  sortDisjunctionProps (reduce (Disjunction [Disjunction [p, q], Disjunction [r]])) ===
    sortDisjunctionProps (Disjunction [p, q, r])
  Right True === interpret truth (Disjunction [Disjunction [p], Disjunction [q]])

dnfTest = script do
  let
    p = Proposition 1
    q = Proposition 2
    r = Proposition 3
    s = Proposition 4
  toDNF p === Disjunction [Conjunction [p]]
  toDNF (Conjunction [p]) === Disjunction [Conjunction [p]]
  toDNF (Disjunction [p]) === Disjunction [Conjunction [p]]
  toDNF (Negation p) === Disjunction [Conjunction [Negation p]]
  toDNF (Conjunction [Negation p]) === Disjunction [Conjunction [Negation p]]
  toDNF (Disjunction [Negation p]) === Disjunction [Conjunction [Negation p]]
  toDNF (Negation (Conjunction [p])) === Disjunction [Conjunction [Negation p]]
  toDNF (Negation (Disjunction [p])) === Disjunction [Conjunction [Negation p]]
  toDNF (Conjunction [Disjunction [p, q], r]) === Disjunction [Conjunction [p, r], Conjunction [q, r]]
  toDNF (Conjunction [p, Disjunction [q, r]]) === Disjunction [Conjunction [p, q], Conjunction [p, r]]
  toDNF (Negation (Conjunction [p, q])) === Disjunction [Conjunction [Negation p], Conjunction [Negation q]]
  toDNF (Negation (Disjunction [p, q])) === Disjunction [Conjunction [Negation p, Negation q]]
  toDNF (Negation (Conjunction [p, q, r])) === Disjunction [Conjunction [Negation p], Conjunction [Negation q], Conjunction [Negation r]]
  toDNF (Negation (Disjunction [p, q, r])) === Disjunction [Conjunction [Negation p, Negation q, Negation r]]
  toDNF (Conjunction [Disjunction [Conjunction [p, q], r], s]) === Disjunction [Conjunction [p, q, s], Conjunction [r, s]]
