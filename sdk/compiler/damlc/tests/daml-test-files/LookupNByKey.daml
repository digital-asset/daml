-- @SUPPORTS-LF-FEATURE DAML_NUCK

module LookupNByKey where

import DA.ContractKeys
-- import Daml.Script

template WithKey
  with
    p : Party
  where
    signatory p
    key p : Party
    maintainer key

template Helper
  with
    p : Party
  where
    signatory p
    choice PerformLookupNByKey : ()
      controller p
      do contracts <- lookupNByKey @WithKey 1 p
         case contracts of
           (contract :: _) -> do
             pure ()
           [] ->
             abort "Assertion failed: lookupNByKey returned an empty list."
    choice PerformLookupAllByKey : ()
      controller p
      do contracts <- lookupAllByKey @WithKey p
         case contracts of
           (contract :: _) -> do
             pure ()
           [] ->
             abort "Assertion failed: lookupAllByKey returned an empty list."

