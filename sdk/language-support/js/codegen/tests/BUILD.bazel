load("//rules_daml:daml.bzl", "daml_compile")
load("@build_environment//:configuration.bzl", "sdk_version")
load("@os_info//:os_info.bzl", "is_windows")

# This rule builds a dar from the daml sources under the 'daml'
# directory. It is referenced from the 'build-and-lint-test' target that
# follows.
daml_compile(
    name = "build-and-lint",
    srcs = glob(
        ["daml/**/*.daml"],
        exclude = ["daml/Hidden.daml"],
    ),
    enable_interfaces = True,
    # TODO(https://github.com/digital-asset/daml/issues/18457): remove contract keys from these
    #  daml files or split the test into two tests, one with contract keys and without, and revert
    #  to the default target version.
    target = "2.dev",
    version = "1.0.0",
)

daml_compile(
    name = "hidden",
    srcs = ["daml/Hidden.daml"],
    data_dependencies = ["build-and-lint.dar"],
    enable_interfaces = True,
    project_name = "hidden",
    # TODO(https://github.com/digital-asset/daml/issues/18457): remove contract keys from these
    #  daml files or split the test into two tests, one with contract keys and without, and revert
    #  to the default target version.
    target = "2.dev",
)

# build-and-lint
# ==============
#
# 'build-and-lint.sh' is an integration test. It builds a DAR from
#  some Daml, invokes daml2js on the DAR, uploads the DAR to a ledger
#  and then runs tests on the TypeScript generated by daml2js via a
#  json-api connected to the ledger.
#
#  The main inputs to 'build-and-lint' are:
#     - Bazel artifacts : '@daml/types' (this is an npm packages);
#     - Source artifacts:
#       - 'ts/codegen/tests/daml/*'
#         The Daml that goes into the DAR ('build-and-lint-1.0.0.dar');
#       - 'ts/codegen/tests/ts/*'
#         A pnpm workspace root containing a single TypeScript package
#         'build-and-lint-test' which houses the test driver 'test.ts'.
#
# 'build-and-lint' creates a temp directory ('root' say), and uses the
# above inputs (via filesystem copies, damlc, daml2js and pnpm install)
# to produce a filesystem with the following structure:
#
#   root/
#      build-and-lint-test/
#        src/
#          __tests__/
#            test.ts
#      daml2js/
#        build-and-lint-1.0.0/  -- The artifacts generated of 'build-and-lint-1.0.0.dar'
#        057eed/
#        ...
#      package.json  -- Singleton package workspace : build-and-lint-test
#      node_modules/
#        @daml/
#          types/
#        ...
#
# In more detail, the actions of 'build-and-lint' are to:
#  - Invoke 'daml2js' on 'build-and-lint-1.0.0.dar' to produce bindings
#    (in the 'daml2js' directory);
#  - Invoke from 'root':
#    - 'pnpm install';
#    - 'pnpm run build';
#    - 'pnpm run lint';
#  - Finally, invoke 'pnpm test' from the 'root/build-and-lint' directory.
#
# That last step causes 'build-and-lint/src/__tests__/test.ts' to be executed which:
#  - Spins up a canton participant and domain running the 'build-and-lint-1.0.0.dar';
#    - Configures a http-json-api endpoint built into the participant;
#  - Evaluates assertions of http-json-api specified ledger operations
#    involving contracts defined by the dar;
#  - Gracefully tears down the processes it started when its work is done.
# All in all, a pretty slick bit of work!
sh_test(
    name = "build-and-lint-test",
    size = "large",
    srcs = ["build-and-lint.sh"],
    args = [
        "$(JAVA_ROOTPATH)",
        "$(location @pnpm//:pnpm)",
        "$(location //language-support/js/codegen:codegen)",
        "$(location //canton:community_app_deploy.jar)",
        "$(location :build-and-lint.dar)",
        "$(location ts/package.json)",
        "$(location //language-support/js/daml-types:npm_package)",
        sdk_version,
        # TODO(#14706): revert to model-tests-default once the default major
        #  version is 2
        "$(location //test-common:model-tests-2.1.dar)",
        "$(location :hidden.dar)",
        "$(location @grpcurl//:bin)",
    ],
    data = [
        ":build-and-lint.dar",
        ":hidden.dar",
        "//language-support/js/codegen",
        "@pnpm//:pnpm",
        "@rules_java//toolchains:current_java_runtime",
        "//canton:community_app_deploy.jar",
        "//language-support/js/daml-types:npm_package",
        # TODO(#14706): revert to model-tests-default once the default major
        #  version is 2
        "//test-common:model-tests-2.1.dar",
        "@grpcurl//:bin",
    ] + glob(
        ["ts/**"],
        exclude = [
            "ts/**/node_modules/**",
            "ts/**/lib/**",
        ],
    ),
    # Spinning up jest, Canton and the JSON API is expensive.
    # We get some timeouts during startup with 2 cpus so we set it to 4 to reduce
    # system load.
    # Running exclusively at this time to avoid port clashes, due to lack of freeport in ts
    # Consider porting this to scala.
    tags = ["exclusive"],
    toolchains = [
        "@rules_java//toolchains:current_java_runtime",
    ],
    deps = [
        "@bazel_tools//tools/bash/runfiles",
    ],
) if not is_windows else None

config_setting(
    name = "on_linux_amd64",
    constraint_values = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
)

config_setting(
    name = "on_osx_amd64",
    constraint_values = [
        "@platforms//cpu:x86_64",
        "@platforms//os:osx",
    ],
)

config_setting(
    name = "on_osx_arm64",
    constraint_values = [
        "@platforms//cpu:aarch64",
        "@platforms//os:osx",
    ],
)

sh_test(
    name = "npm-update-check",
    srcs = ["npm_check.sh"],
    args = [
        "$(location //language-support/js/codegen)",
        "$(location //bazel_tools:jq_bin)",
        "$(location :npmcheck1.dar)",
        "$(location :npmcheck2.dar)",
        sdk_version,
    ] + select({
        ":on_linux_amd64": [
            "$(rlocationpath @nodejs_linux_amd64//:npm)",
            "$(rlocationpath @nodejs_linux_amd64//:node)",
        ],
        ":on_osx_amd64": [
            "$(rlocationpath @nodejs_darwin_amd64//:npm)",
            "$(rlocationpath @nodejs_darwin_amd64//:node)",
        ],
        ":on_osx_arm64": [
            "$(rlocationpath @nodejs_darwin_arm64//:npm)",
            "$(rlocationpath @nodejs_darwin_arm64//:node)",
        ],
    }),
    data = [
        ":npmcheck1.dar",
        ":npmcheck2.dar",
        "//language-support/js/codegen",
        "//bazel_tools:jq_bin",
    ] + select({
        ":on_linux_amd64": [
            "@nodejs_linux_amd64//:node",
            "@nodejs_linux_amd64//:npm",
            "@nodejs_linux_amd64//:npm_files",
        ],
        ":on_osx_amd64": [
            "@nodejs_darwin_amd64//:node",
            "@nodejs_darwin_amd64//:npm",
            "@nodejs_darwin_amd64//:npm_files",
        ],
        ":on_osx_arm64": [
            "@nodejs_darwin_arm64//:node",
            "@nodejs_darwin_arm64//:npm",
            "@nodejs_darwin_arm64//:npm_files",
        ],
    }),
    deps = [
        "@bazel_tools//tools/bash/runfiles",
    ],
) if not is_windows else None

daml_compile(
    name = "npmcheck1",
    srcs = ["daml/Npm1.daml"],
    # TODO(#14706): remove explicit target once the default major version is 2
    target = "2.1",
)

daml_compile(
    name = "npmcheck2",
    srcs = ["daml/Npm2.daml"],
    # TODO(#14706): remove explicit target once the default major version is 2
    target = "2.1",
)
