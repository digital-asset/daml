diff --git a/haskell/private/cc_wrapper.py.tpl b/haskell/private/cc_wrapper.py.tpl
--- a/haskell/private/cc_wrapper.py.tpl
+++ b/haskell/private/cc_wrapper.py.tpl
@@ -88,16 +88,62 @@
 CODESIGN_ALLOCATE = "{:bindir:}/codesign_allocate"
 OTOOL = "{:bindir:}/otool"

+INJECT_COMPILE_FLAGS = {:compile_flags:}
+INJECT_LINK_FLAGS = {:link_flags:}
+
+
+def toolchain_exec_root():
+    return os.environ.get("RULES_HASKELL_EXEC_ROOT") or os.getcwd()
+
+
+def resolve_execroot_path(body, exec_root):
+    direct = os.path.join(exec_root, body)
+    if os.path.exists(direct):
+        return direct
+    # Baked-in generated paths carry the wrapper's own (exec) config, which is
+    # not the invoking action's config; only the action's config tree is staged
+    # in its sandbox, so glob for whichever bazel-out config is present.
+    parts = body.split("/")
+    if len(parts) > 3 and parts[0] == "bazel-out" and parts[2] == "bin":
+        pattern = os.path.join(exec_root, "bazel-out", "*", "bin", *parts[3:])
+        matches = sorted(glob.glob(pattern))
+        if matches:
+            return matches[0]
+    return direct
+
+
+def absolutize_toolchain_flag(tok, exec_root):
+    for prefix in ("-isystem", "-iquote", "-idirafter", "-I", "-L", "-B", "-F", ""):
+        if not tok.startswith(prefix):
+            continue
+        body = tok[len(prefix):]
+        if body.startswith("external/") or body.startswith("bazel-out/"):
+            return prefix + resolve_execroot_path(body, exec_root)
+        break
+    return tok
+
+
+def injected_toolchain_flags(linking):
+    exec_root = toolchain_exec_root()
+    flags = list(INJECT_COMPILE_FLAGS)
+    if linking:
+        flags = flags + list(INJECT_LINK_FLAGS)
+    return [absolutize_toolchain_flag(flag, exec_root) for flag in flags]
+

