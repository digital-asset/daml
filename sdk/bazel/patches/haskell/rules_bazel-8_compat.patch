diff --git a/haskell/private/get_cpu_value_compat.bzl b/haskell/private/get_cpu_value_compat.bzl
new file mode 100644
--- /dev/null
+++ b/haskell/private/get_cpu_value_compat.bzl
@@ -0,0 +1,18 @@
+def get_cpu_value(ctx):
+    os_name = ctx.os.name.lower()
+    arch = ctx.os.arch
+
+    if "windows" in os_name:
+        if arch in ["aarch64", "arm64"]:
+            return "arm64_windows"
+        return "x64_windows"
+
+    if "mac os x" in os_name or "darwin" in os_name:
+        if arch in ["aarch64", "arm64"]:
+            return "darwin_arm64"
+        return "darwin_x86_64"
+
+    if "linux" in os_name:
+        return "aarch64" if arch in ["aarch64", "arm64"] else "k8"
+
+    fail("Unsupported host platform: os={}, arch={}".format(ctx.os.name, arch))
