#!/usr/bin/env bash

nix_tool() {
  echo "$(nix-build ./nix/default.nix -A "tools.$1" -Q --no-out-link)/$2"
}

# Expose our tools in /dev-env/bin and our version of nixpkgs
semver="$(nix_tool semver bin/semver)"
echo "export NIX_USER_CONF_FILES=\"$( dirname $( readlink -f "${BASH_SOURCE[0]}" ) )/../etc/nix.conf:\${NIX_USER_CONF_FILES:-}:\${XDG_CONFIG_HOME:-\${HOME}/.config}/nix/nix.conf\""
